# Copy to .env — never commit .env to git

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DATABASE=ai_builder
MONGODB_COLLECTION=documents
MONGODB_INDEX_NAME=vector_index
MONGODB_EVAL_COLLECTION=eval_results

# OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct
OPENROUTER_ROUTER_MODEL=meta-llama/llama-3.2-3b-instruct

# Voyage AI (https://www.voyageai.com)
VOYAGE_API_KEY=pa-...
VOYAGE_EMBED_MODEL=voyage-3-lite

# RAG parameters
RETRIEVAL_TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Evaluation thresholds
MIN_FAITHFULNESS_SCORE=0.7
MIN_RELEVANCY_SCORE=0.6
DRIFT_ALERT_THRESHOLD=0.15
DRIFT_WINDOW_HOURS=24
DRIFT_BASELINE_DAYS=7

# OpenTelemetry
# false = console output (development)
# true = send to OTLP collector (Dash0 or local)
OTEL_ENABLED=false
OTEL_ENDPOINT=https://ingress.eu-west-1.aws.dash0.com:4317
OTEL_SERVICE_NAME=ai-builder
# Dash0 auth token (optional — only needed when OTEL_ENABLED=true)
DASH0_AUTH_TOKEN=
